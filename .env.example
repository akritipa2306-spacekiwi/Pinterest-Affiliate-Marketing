# Pinterest Affiliate Marketing — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Required for AI features (discovery + pin content generation) ──────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Required for Amazon affiliate links ───────────────────────────────────
AMAZON_ASSOCIATE_ID=your-tag-20

# ── Required for image generation (Stage 3) ───────────────────────────────
# Get your key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-api-key-here
